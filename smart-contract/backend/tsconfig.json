{
  "compilerOptions": {
    "target": "es2020",
    "module": "commonjs",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "rootDir": "./",
    "resolveJsonModule": true
  },
  "include": [
    "./hardhat.config.ts",
    "./ignition/**/*.ts",
    "./test/**/*.ts",
    "./scripts/**/*.ts"
  ]
}